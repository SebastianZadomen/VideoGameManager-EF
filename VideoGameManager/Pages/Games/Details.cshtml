@page "{id:int}"
@model VideoGameManager.Pages.Games.DetailsModel
@{
    ViewData["Title"] = "Details Page";
}
<div>
    <h1 class="text-center mb-5">@Model.GameSelected.Title</h1>
    <div class="row">
        <div class="col-md-6">
            <div class="mb-4">
                <label class="fw-bold fs-4">Genre:</label>
                <p class="fs-3">@Model.GameSelected.Genre</p>
            </div>
            
            <div class="mb-4">
                <label class="fw-bold fs-4">Score:</label>
                <p class="fs-3 text-primary">@Model.GameSelected.Score / 10</p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="mb-4">
                <label class="fw-bold fs-4">Year:</label>
                <p class="fs-3">@Model.GameSelected.Year</p>
            </div>

            <div class="mb-4">
                <label class="fw-bold fs-4">Description:</label>
                <p class="fs-5">@Model.GameSelected.Description</p>
            </div>
        </div>
    </div>
    <br></br>
    <a class="btn btn-info" asp-page="./Index">Return</a>

</div>
