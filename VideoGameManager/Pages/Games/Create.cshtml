@page
@model VideoGameManager.Pages.Games.CreateModel
@{
    ViewData["Title"] = "Create Page";
}
<h1 class="text-center">Add Game</h1>
<form method ="post">
    <div class="form-row">
        <div class="form-group col-md-6">
            <label asp-for="GameCreated.Title">Title</label>
            <input type="text" asp-for="GameCreated.Title" class="form-control" placeholder="Tittle">
            <span asp-validation-for="GameCreated.Title" class="text-danger"></span>
        </div>
        <div class="form-group col-md-6">
            <label asp-for="GameCreated.Year">Date</label>
            <input type="number" asp-for="GameCreated.Year" class="form-control" placeholder="Date">
            <span asp-validation-for="GameCreated.Year" class="text-danger"></span>
        </div>
    </div>
    <div class="form-group">
        <label asp-for="GameCreated.Genre">Genre</label>
        <input type="text" asp-for="GameCreated.Genre" class="form-control" placeholder="Genre">
        <span asp-validation-for="GameCreated.Genre" class="text-danger"></span>

    </div>
    <div class="form-group">
        <label asp-for="GameCreated.Score">Score</label>
        <input type="number" step="0.01" class="form-control" asp-for="GameCreated.Score" placeholder="Score">
        <span asp-validation-for="GameCreated.Score" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="GameCreated.Description">Description</label>
        <input type="textarea" class="form-control" asp-for="GameCreated.Description" placeholder="Description">
        <span asp-validation-for="GameCreated.Description" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="GameCreated.DeveloperId" class="control-label">Developer</label>
        <select asp-for="GameCreated.DeveloperId" class="form-control">
            <option value="">-- Select Developer --</option>
        
            @foreach (var dev in Model.DeveloperList)
            {
                <option value="@dev.Id">@dev.Name</option>
            }
        </select>
        <span asp-validation-for="GameCreated.DeveloperId" class="text-danger"></span>
    </div>
    <br></br>
    <button type="submit"  class="btn btn-primary">Created</button>
</form>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}